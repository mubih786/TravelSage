PRAGMA foreign_keys = ON;

DROP TABLE IF EXISTS reviews;
DROP TABLE IF EXISTS wishlist;
DROP TABLE IF EXISTS compare_list;
DROP TABLE IF EXISTS itinerary;
DROP TABLE IF EXISTS search_history;
DROP TABLE IF EXISTS destinations;

CREATE TABLE destinations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    place_name TEXT NOT NULL,
    state TEXT NOT NULL,
    region TEXT NOT NULL,
    terrain TEXT NOT NULL,
    budget_category TEXT NOT NULL,
    best_season TEXT NOT NULL,
    best_months TEXT NOT NULL,
    tags TEXT NOT NULL,
    travel_type TEXT NOT NULL,
    activity_level TEXT NOT NULL,
    trip_duration TEXT NOT NULL,
    accommodation TEXT NOT NULL,
    travel_mode TEXT NOT NULL,
    age_group TEXT NOT NULL,
    crowd_level TEXT NOT NULL,
    weather_type TEXT NOT NULL,
    temperature_range TEXT NOT NULL,
    trip_purpose TEXT NOT NULL,
    food_options TEXT NOT NULL,
    connectivity TEXT NOT NULL,
    accessibility TEXT NOT NULL,
    safety_level TEXT NOT NULL,
    eco_friendly INTEGER DEFAULT 0,
    experience_type TEXT NOT NULL,
    distance_from_metro TEXT NOT NULL,
    nearest_airport TEXT NOT NULL,
    description TEXT NOT NULL,
    things_to_do TEXT NOT NULL,
    best_time_detail TEXT NOT NULL,
    image_url TEXT DEFAULT '/static/images/default.jpg',
    google_maps_url TEXT DEFAULT '#',
    rating REAL DEFAULT 4.0,
    view_count INTEGER DEFAULT 0,
    is_trending INTEGER DEFAULT 0,
    is_hidden_gem INTEGER DEFAULT 0,
    is_family_fav INTEGER DEFAULT 0,
    is_romantic INTEGER DEFAULT 0,
    is_backpacker INTEGER DEFAULT 0,
    altitude_meters INTEGER DEFAULT 0,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE wishlist (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    session_id TEXT NOT NULL,
    destination_id INTEGER NOT NULL,
    saved_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY(destination_id)
        REFERENCES destinations(id)
        ON DELETE CASCADE
);

CREATE TABLE search_history (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    session_id TEXT NOT NULL,
    budget TEXT,
    season TEXT,
    interests TEXT,
    region TEXT,
    travel_type TEXT,
    activity_level TEXT,
    trip_purpose TEXT,
    duration TEXT,
    crowd TEXT,
    age_group TEXT,
    results_count INTEGER DEFAULT 0,
    searched_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE reviews (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    destination_id INTEGER NOT NULL,
    session_id TEXT,
    reviewer_name TEXT DEFAULT 'Anonymous',
    rating REAL NOT NULL,
    comment TEXT,
    helpful_votes INTEGER DEFAULT 0,
    reviewed_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY(destination_id)
        REFERENCES destinations(id)
        ON DELETE CASCADE
);

CREATE TABLE compare_list (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    session_id TEXT NOT NULL,
    destination_id INTEGER NOT NULL,
    added_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY(destination_id)
        REFERENCES destinations(id)
        ON DELETE CASCADE
);

CREATE TABLE itinerary (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    session_id TEXT NOT NULL,
    title TEXT,
    destination_ids TEXT,
    total_days INTEGER,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);


INSERT INTO destinations (
    place_name, state, region, terrain, budget_category, best_season, best_months,
    tags, travel_type, activity_level, trip_duration, accommodation, travel_mode,
    age_group, crowd_level, weather_type, temperature_range, trip_purpose, food_options,
    connectivity, accessibility, safety_level, eco_friendly, experience_type,
    distance_from_metro, nearest_airport, description, things_to_do, best_time_detail,
    image_url, google_maps_url, rating, is_trending, is_hidden_gem, is_family_fav, is_romantic, is_backpacker, altitude_meters
) VALUES

